# dev-only test deps — reinstalled from package-lock.json in CI
tests/node_modules/

# dev-only lint deps (root) — reinstalled from package-lock.json in CI
node_modules/
# scratch concat file written by tools/lint.js while linting
tools/.eslint-concat.js

# generated versioned build copies — built on demand from src/ (index.html is the
# committed, GitHub Pages-served artifact; dist/ copies are not published)
dist/

# throwaway screenshots from tools/shoot.js (dev-only visual inspection)
tools/shots/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# logs
npm-debug.log*
